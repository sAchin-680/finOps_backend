# Copy this file to .env and fill in your values
# cp .env.example .env

NODE_ENV=production
PORT=3000

# MongoDB connection string
# Local:   mongodb://localhost:27017/finops
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/finops
MONGO_URI=mongodb://localhost:27017/finops

# JWT secret — use a long, random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h
